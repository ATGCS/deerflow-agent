{
  "name": "ytpanel",
  "version": "1.0.0",
  "private": true,
  "description": "YTPanel - 可视化管理面板，基于 Tauri v2 的跨平台桌面应用",
  "type": "module",
  "author": "qingchencloud",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/qingchencloud/deerpanel",
  "repository": {
    "type": "git",
    "url": "https://github.com/qingchencloud/deerpanel.git"
  },
  "bugs": {
    "url": "https://github.com/qingchencloud/deerpanel/issues"
  },
  "keywords": [
    "ytpanel",
    "ai-agent",
    "tauri",
    "desktop-app",
    "management-panel"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icon:regen": "tauri icon docs/ytpanel-app-icon-square.png -o src-tauri/icons",
    "icon:generate": "python scripts/gen-ytpanel-icon.py && tauri icon docs/ytpanel-app-icon-square.png -o src-tauri/icons && node -e \"require('fs').copyFileSync('src-tauri/icons/icon.ico','public/favicon.ico')\"",
    "serve": "node scripts/serve.js",
    "version:sync": "node scripts/sync-version.js",
    "version:set": "node scripts/sync-version.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001784",
    "happy-dom": "^20.8.9",
    "typescript": "~5.7.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.2"
  }
}
